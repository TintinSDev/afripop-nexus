generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Property {
  id               Int           @id @default(autoincrement())
  title            String
  location         String
  description      String
  totalValuation   Float // AI Predicted
  pricePerFraction Float // AI Predicted
  growthPotential  Float // AI Score (1-10)
  createdAt        DateTime      @default(now())
  shares           Share[]
  transactions     Transaction[]
}

model Share {
  id         Int      @id @default(autoincrement())
  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id])
  ownerPhone String
  percentage Float // e.g. 1.0 for 1% ownership
}

model Transaction {
  id         String   @id // Use the AT Transaction ID here
  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id])
  amount     Float
  type       String // "RENT_COLLECTION" or "DIVIDEND_PAYOUT"
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
}
